{
  "name": "vaultbox-api",
  "version": "1.0.0",
  "description": "Secure cloud storage API with user accounts, plan-based quotas, signed downloads, suspension logic, audit logs, and admin controls.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "npx prisma generate",
    "deploy:migrate": "npx prisma migrate deploy",
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "cloud-storage",
    "file-storage",
    "fastify",
    "prisma",
    "postgresql",
    "redis",
    "jwt",
    "swagger",
    "api",
    "saas"
  ],
  "author": "Williams Ashibuogwu",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/client": "^6.15.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "prisma": "^6.15.0",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
